FROM python:3.11-slim

WORKDIR /app

# Upgrade package metadata tools to address CVE-2026-23949 and CVE-2026-24049
RUN pip install --no-cache-dir --upgrade pip setuptools wheel>=0.46.2 jaraco.context>=6.1.0

COPY requirements.mock.txt .
RUN pip install --no-cache-dir -r requirements.mock.txt

COPY scripts/mock_producer.py ./mock_producer.py

CMD ["python", "mock_producer.py"]
