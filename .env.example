# ITS Detection Edge - Environment Variables
# Copy this to .env and adjust as needed

# Camera & Capture
CAMERA_ID=cam_01
CAMERA_URL=rtsp://your-camera-url
FRAME_WIDTH=1920
FRAME_HEIGHT=1080

# Machine Learning
MODEL_PATH=models/yolov8n.pt
DETECTION_CONFIDENCE=0.4
TRACKER_CONFIG=config/bytetrack.yaml

# Transport (Kafka)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=traffic.events.raw

# API
API_PORT=8001
METRICS_PORT=9091
