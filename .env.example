# ITS Detection Edge - Environment Variables
# Copy this to .env and adjust as needed

# Camera & Capture
CAMERA_ID=cam_01
CAMERA_URL=tests/test.mp4
FRAME_WIDTH=1920
FRAME_HEIGHT=1080
STATUS_INTERVAL_SECONDS=5
LOG_DETECTIONS=false
DISPLAY_VIDEO=true
DRAW_LANES=true

# Machine Learning
MODEL_PATH=yolov8n.pt
DETECTION_CONFIDENCE=0.4
TRACKER_CONFIG=bytetrack.yaml
FRAME_SKIP=0

# Transport (Kafka)
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=traffic.events.raw

# API
API_PORT=8001
METRICS_PORT=9091
